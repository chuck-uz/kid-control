<Window x:Class="KidControl.UiHost.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Kid Control"
        Icon="pack://application:,,,/Resources/ui_icon.ico"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual"
        AllowsTransparency="True"
        Background="Transparent"
        Width="150"
        Height="50"
        Opacity="1">

    <Grid>
        <Border x:Name="WidgetBorder"
                Width="260"
                Height="140"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,10,10,0"
                Style="{StaticResource GlassCardStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Grid Width="98" Height="98" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Ellipse Stroke="{StaticResource RingBackgroundBrush}"
                             StrokeThickness="8" />
                    <Path x:Name="WidgetProgressPath"
                          Stroke="{StaticResource PrimaryBrush}"
                          StrokeThickness="8"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round" />
                    <TextBlock Text="{Binding TimeRemaining}"
                               Style="{StaticResource BodyTextStyle}"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Grid>

                <StackPanel Grid.Column="1"
                            VerticalAlignment="Center"
                            Margin="12,0,0,0">
                    <TextBlock Text="KidControl"
                               Style="{StaticResource HeadingTextStyle}"
                               FontSize="20" />
                    <TextBlock Text="{Binding SessionLabel}"
                               Style="{StaticResource BodyTextStyle}"
                               Margin="0,8,0,0" />
                    <TextBlock Text="{Binding TimeRemaining}"
                               Style="{StaticResource TimerTextStyle}"
                               Margin="0,6,0,0" />
                </StackPanel>
            </Grid>
        </Border>

        <Border x:Name="BlockOverlay"
                Background="{StaticResource BlockBackgroundBrush}"
                Visibility="Collapsed">
            <Grid>
                <Canvas IsHitTestVisible="False" Opacity="0.55">
                    <Ellipse x:Name="Star1" Fill="#55FFFFFF" Width="3" Height="3" Canvas.Left="150" Canvas.Top="120" />
                    <Ellipse x:Name="Star2" Fill="#40FFFFFF" Width="4" Height="4" Canvas.Left="520" Canvas.Top="250" />
                    <Ellipse x:Name="Star3" Fill="#45FFFFFF" Width="3" Height="3" Canvas.Left="860" Canvas.Top="170" />
                    <Ellipse x:Name="Star4" Fill="#35FFFFFF" Width="5" Height="5" Canvas.Left="1180" Canvas.Top="320" />
                    <Ellipse x:Name="Star5" Fill="#50FFFFFF" Width="3" Height="3" Canvas.Left="1460" Canvas.Top="140" />
                </Canvas>

                <StackPanel VerticalAlignment="Center"
                            HorizontalAlignment="Center"
                            Margin="24">
                    <TextBlock Text="KidControl"
                               Style="{StaticResource BodyTextStyle}"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,20" />
                    <TextBlock Text="Время игры закончилось. Перерыв."
                               x:Name="BlockReasonText"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontFamily="{StaticResource UiFontFamily}"
                               FontWeight="SemiBold"
                               FontSize="44"
                               Margin="0,0,0,28"
                               TextAlignment="Center"
                               LineHeight="56"
                               HorizontalAlignment="Center" />
                    <TextBlock x:Name="BlockedTimerText"
                               Text="{Binding TimeRemaining}"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontWeight="SemiBold"
                               FontFamily="{StaticResource UiFontFamily}"
                               FontSize="96"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               RenderTransformOrigin="0.5,0.5">
                        <TextBlock.RenderTransform>
                            <ScaleTransform ScaleX="1" ScaleY="1" />
                        </TextBlock.RenderTransform>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
