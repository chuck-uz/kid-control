<Window x:Class="KidControl.UiHost.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Kid Control"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual"
        AllowsTransparency="True"
        Background="Transparent"
        Width="150"
        Height="50"
        Opacity="1">

    <Grid>
        <Border x:Name="WidgetBorder"
                Width="200"
                Height="80"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,8,8,0"
                CornerRadius="8"
                Background="#AA1E1E1E"
                BorderBrush="#CCFFFFFF"
                BorderThickness="1">
            <TextBlock Text="{Binding TimeRemaining}"
                       Foreground="White"
                       FontWeight="SemiBold"
                       FontFamily="Consolas"
                       FontSize="17"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center">
                <TextBlock.Effect>
                    <DropShadowEffect BlurRadius="8"
                                      ShadowDepth="0"
                                      Opacity="0.9"
                                      Color="Black" />
                </TextBlock.Effect>
            </TextBlock>
        </Border>

        <Border x:Name="BlockOverlay"
                Background="Black"
                Visibility="Collapsed">
            <StackPanel VerticalAlignment="Center"
                        HorizontalAlignment="Center">
                <TextBlock Text="Время игры закончилось. Перерыв."
                           Foreground="White"
                           FontFamily="Segoe UI"
                           FontWeight="SemiBold"
                           FontSize="36"
                           Margin="0,0,0,24"
                           TextAlignment="Center"
                           HorizontalAlignment="Center" />
                <TextBlock x:Name="BlockedTimerText"
                           Text="{Binding TimeRemaining}"
                           Foreground="White"
                           FontWeight="Bold"
                           FontFamily="Consolas"
                           FontSize="88"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           RenderTransformOrigin="0.5,0.5">
                    <TextBlock.RenderTransform>
                        <ScaleTransform ScaleX="1" ScaleY="1" />
                    </TextBlock.RenderTransform>
                </TextBlock>
            </StackPanel>
        </Border>
    </Grid>
</Window>
