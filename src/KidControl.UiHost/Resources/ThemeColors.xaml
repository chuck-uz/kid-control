<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Color x:Key="ColorPrimary">#0078D4</Color>
    <Color x:Key="ColorPrimaryAlt">#6200EE</Color>
    <Color x:Key="ColorLightBackground">#F3F3F3</Color>
    <Color x:Key="ColorDarkBackground">#202020</Color>
    <Color x:Key="ColorSurfaceLight">#80FFFFFF</Color>
    <Color x:Key="ColorSurfaceDark">#80000000</Color>
    <Color x:Key="ColorTextPrimaryLight">#000000</Color>
    <Color x:Key="ColorTextSecondaryLight">#666666</Color>
    <Color x:Key="ColorTextPrimaryDark">#FFFFFF</Color>
    <Color x:Key="ColorTextSecondaryDark">#AAAAAA</Color>
    <Color x:Key="ColorWidgetBorder">#AAFFFFFF</Color>
    <Color x:Key="ColorRingBackground">#55FFFFFF</Color>

    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource ColorPrimary}" />
    <SolidColorBrush x:Key="PrimaryAltBrush" Color="{StaticResource ColorPrimaryAlt}" />
    <SolidColorBrush x:Key="WidgetGlassBrush" Color="{StaticResource ColorSurfaceDark}" />
    <SolidColorBrush x:Key="WidgetBorderBrush" Color="{StaticResource ColorWidgetBorder}" />
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource ColorTextPrimaryDark}" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource ColorTextSecondaryDark}" />
    <SolidColorBrush x:Key="RingBackgroundBrush" Color="{StaticResource ColorRingBackground}" />

    <LinearGradientBrush x:Key="BlockBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#0A2A66" Offset="0" />
        <GradientStop Color="#050914" Offset="0.6" />
        <GradientStop Color="#020205" Offset="1" />
    </LinearGradientBrush>
</ResourceDictionary>
