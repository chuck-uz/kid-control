<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DropShadowEffect x:Key="GlassShadowEffect"
                      BlurRadius="22"
                      ShadowDepth="0"
                      Opacity="0.35"
                      Color="#000000" />

    <Style x:Key="GlassCardStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource WidgetGlassBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource WidgetBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Effect" Value="{StaticResource GlassShadowEffect}" />
        <Setter Property="Padding" Value="16" />
    </Style>
</ResourceDictionary>
